{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=polaris_exchange;Username=polaris;Password=polaris123"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
